# =============================================================================
# Zapp Hub - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# MQTT (Mosquitto)
# -----------------------------------------------------------------------------
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=zapp-hub
# QoS level for MQTT messages (0, 1, or 2)
MQTT_QOS=1

# -----------------------------------------------------------------------------
# Database (SQLite)
# -----------------------------------------------------------------------------
DB_PATH=./data/zapp.db

# -----------------------------------------------------------------------------
# Authentication (Google OAuth)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# JWT secret for session tokens (generate a strong random string)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY=7d

# -----------------------------------------------------------------------------
# Health Monitoring
# -----------------------------------------------------------------------------
# Time in seconds before a device is considered offline
DEVICE_OFFLINE_THRESHOLD_SECONDS=30
# Heartbeat interval expected from devices (seconds)
DEVICE_HEARTBEAT_INTERVAL_SECONDS=10

# -----------------------------------------------------------------------------
# OTA
# -----------------------------------------------------------------------------
# Directory where firmware binaries are stored
OTA_FIRMWARE_DIR=./firmware

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# MCP (LLM Integration)
# -----------------------------------------------------------------------------
# Port for the MCP tool server (can be same as main API or separate)
MCP_ENABLED=true
MCP_API_KEY=change-this-to-a-strong-mcp-api-key

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (use * for development only)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# -----------------------------------------------------------------------------
# Property / Hub Identity
# -----------------------------------------------------------------------------
PROPERTY_ID=default-property
HUB_NAME=Zapp Hub
